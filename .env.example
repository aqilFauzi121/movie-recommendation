# Dapatkan API Key dari https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Supabase URL project Anda
SUPABASE_URL=https://your-project-id.supabase.co

# Gunakan service role key untuk server-side app (lebih aman)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Fallback lama (opsional, tidak direkomendasikan untuk deployment publik)
SUPABASE_KEY=your_supabase_anon_key_here
